{
  "id": "weather_context",
  "name": "Meteo",
  "version": "1.0.0",
  "description": "Aggiunge contesto meteo storico alle foto (Open-Meteo). Richiede connessione internet al momento dell'esecuzione.",
  "icon": "🌤",
  "author": "OffGallery",
  "license": "OffGallery Plugins License v1.0 — Proprietary, no redistribution",
  "entry_point": "weather_ui.py",
  "requires_db": false,
  "requires_download": false,
  "min_offgallery_version": "1.0",
  "type": "standalone",
  "pipeline_stage": "pre_llm",
  "priority": 30,
  "run_condition": "bioclip_not_null",
  "gallery_action": true,
  "input_fields": ["gps_latitude", "gps_longitude", "datetime_original"],
  "output_fields": ["weather_context"],
  "llm_context_fields": [],
  "db_columns": [
    {"name": "weather_context", "type": "TEXT"}
  ],
  "search_filters": [
    {"field": "weather_condition", "widget": "combobox", "label_key": "weather_condition",
     "db_column": "weather_context", "json_extract": "$.condition"}
  ],
  "enum_fields": {
    "weather_condition": {
      "it": {
        "clear":         "Sereno",
        "partly_cloudy": "Parzialmente nuvoloso",
        "cloudy":        "Nuvoloso",
        "fog":           "Nebbia",
        "drizzle":       "Pioggerella",
        "rain":          "Pioggia",
        "snow":          "Neve",
        "thunderstorm":  "Temporale"
      },
      "en": {
        "clear":         "Clear",
        "partly_cloudy": "Partly cloudy",
        "cloudy":        "Cloudy",
        "fog":           "Fog",
        "drizzle":       "Drizzle",
        "rain":          "Rain",
        "snow":          "Snow",
        "thunderstorm":  "Thunderstorm"
      }
    }
  },
  "labels": {
    "it": {
      "weather_context":   "Contesto meteo",
      "weather_condition": "Condizione meteo"
    },
    "en": {
      "weather_context":   "Weather context",
      "weather_condition": "Weather condition"
    }
  }
}
