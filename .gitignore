# Ignora tutto
*

# Eccezioni: traccia solo questi file/cartelle
!.gitignore
!.gitattributes
!.github/
!.github/workflows/
!.github/workflows/*.yml
!README.md
!CONFIGURATION.md
!TRADEMARK.md
!THIRD_PARTY.md
!PROMPT_ARCHITECTURE.md
!LICENSE
!OffGallery.spec
!requirements_frozen.txt
!VERSION
!update.bat
!update.command
!update.sh
# update_beta.* va SOLO sulla repo privata beta (via git add -f nel workflow beta)
update_beta.*

# Codice Python
!*.py
!gui/
!gui/*.py
!utils/
!utils/*.py
!catalog_readers/
!catalog_readers/*.py
# ╔══════════════════════════════════════════════════════════════════════╗
# ║  PLUGIN — dal 2026-07: il CODICE dei plugin è pubblico (repo main).  ║
# ║  Solo i DATI pesanti (scaricati/generati a runtime) restano esclusi. ║
# ║  I plugin scaricano i propri dati via download_and_build_database(). ║
# ╚══════════════════════════════════════════════════════════════════════╝
# Codice dei plugin: incluso nel repo pubblico
!plugins/
!plugins/**/
!plugins/**/*.py
!plugins/**/*.md
!plugins/**/*.json
!plugins/**/*.txt
# Dati runtime plugin (scaricati/generati a runtime, MAI nel repo) — esclusi
plugins/**/data/
plugins/**/cache/
plugins/**/*.tif
plugins/**/*.db
plugins/**/*.npy
plugins/**/*.bin
plugins/**/weather_cache.db
plugins/*.zip
# Config di stato locale dei plugin (contiene percorsi personali + dati d'uso,
# rigenerato dai default al primo avvio) — MAI nel repo pubblico.
# NB: manifest.json, presets/*.yaml e altri file strutturali restano tracciati.
plugins/**/config.json

# Configurazione
!*.yaml
!*.yml

# Installer (Linux/macOS — script bash e guide)
# I .bat Windows sono obsoleti (sostituiti da OffGallerySetup.exe) e non tracciati
!installer/
!installer/*.py
!installer/*.sh
!installer/*.md
!installer/*.txt
!installer/*.json
installer/*.bat

# Installer GUI (OffGallery Manager)
!A_INSTALLER/
!A_INSTALLER/*.py
!A_INSTALLER/*.md
!A_INSTALLER/*.bat
!A_INSTALLER/*.sh
!A_INSTALLER/*.spec
!A_INSTALLER/*.txt
!A_INSTALLER/components/
!A_INSTALLER/components/*.py
!A_INSTALLER/state/
!A_INSTALLER/state/*.py
!A_INSTALLER/ui/
!A_INSTALLER/ui/*.py
!A_INSTALLER/utils/
!A_INSTALLER/utils/*.py
!A_INSTALLER/assets/
!A_INSTALLER/assets/*.png
!A_INSTALLER/assets/*.ico
!A_INSTALLER/requirements_offgallery.txt

# Documentazione (manuale utente e pagine web pubbliche)
!HTML/
!HTML/USER_MANUAL_IT.html
!HTML/USER_MANUAL_EN.html
!HTML/index.html
!HTML/features.html
!HTML/credits.html
!HTML/CNAME
!HTML/sitemap.xml
!HTML/assets/
!HTML/assets/*

# ESSENZIALI PER L'APP - Includere nel repo
!i18n/
!i18n/*.json
!assets/
!assets/*
!assets/**/*
!exiftool.exe
!exiftool_files/
!exiftool_files/*
!exiftool_files/**/*
!tools/
!tools/*
!tools/**/*

