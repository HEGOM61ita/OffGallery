# Ignora tutto
*

# Eccezioni: traccia solo questi file/cartelle
!.gitignore
!.gitattributes
!README.md
!CONFIGURATION.md
!TRADEMARK.md
!THIRD_PARTY.md
!LICENSE
!OffGallery.spec
!requirements_frozen.txt
!VERSION
!update.bat
!update.command
!update.sh
# update_beta.* va SOLO sulla repo privata beta (via git add -f nel workflow beta)
update_beta.*

# Codice Python
!*.py
!gui/
!gui/*.py
!utils/
!utils/*.py
!catalog_readers/
!catalog_readers/*.py
!plugins/
!plugins/*.py
!plugins/*.md
# Sottodirectory plugin: solo nella repo privata beta, mai nella repo pubblica
plugins/*/
plugins/*/*
# Dati runtime plugin (scaricati/generati a runtime, non nel repo)
plugins/naturarea/*.tif
plugins/naturarea/data/*.db
plugins/naturarea/weather_cache.db
plugins/weather_context/data/*.db
plugins/bionomen/data/*.db
plugins/geospecies/cache/*.json

# Configurazione
!*.yaml
!*.yml

# Installer
!installer/
!installer/*.py
!installer/*.bat
!installer/*.sh
!installer/*.md
!installer/*.txt
!installer/*.json

# Documentazione (manuale utente e pagine web pubbliche)
!docs/
!docs/*.txt
!docs/USER_MANUAL_IT.html
!docs/USER_MANUAL_EN.html
!docs/index.html
!docs/features.html

# ESSENZIALI PER L'APP - Includere nel repo
!i18n/
!i18n/*.json
!assets/
!assets/*
!assets/**/*
!exiftool_files/
!exiftool_files/*
!exiftool_files/**/*

# Cartelle da ignorare (grandi o generate)
aesthetic/
bioclip/
treeoflife/
database/
INPUT/
dist/
build/

# Script di test sperimentali
test_*.py
test_bioclip_llm.py
INPUT_TEST/

# File di backup
*_BACKUP_*
*_OLD*
*_OLD.py

# Database
*.db
*.sqlite
*.sqlite3

# Virtual environment
venv/
env/
.venv/
.env/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Windows system files
desktop.ini
Thumbs.db

# Log files
*.log
processing_log*.txt
tagging_log.txt

# Temp files
*.tmp

# Directory POC / sviluppo locale (non pubblicare)
llm_plugin_poc/
